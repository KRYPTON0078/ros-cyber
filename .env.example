# ROS Cyber environment — copy to .env and customize

ENVIRONMENT=development
ROSCYBER_PROFILE=hardened

DATABASE_URL=postgresql+asyncpg://roscyber:roscyber@postgres:5432/roscyber
REDIS_URL=redis://redis:6379/0

MQTT_HOST=mosquitto
MQTT_PORT=1883

JWT_SECRET=change-me-in-production-use-long-random-string-min-32-chars
JWT_EXPIRE_MINUTES=60

INGESTION_PORT=8000
POLICY_PORT=8001
DASHBOARD_PORT=8002

RATE_LIMIT_PER_MINUTE=120
TELEMETRY_FLOOD_THRESHOLD=50
GPS_JUMP_THRESHOLD_M=500

POLICIES_DIR=policies
KILL_SWITCH_ACTIVE=false
